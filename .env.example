# cc-bootstrap secrets — copy to .env and fill in.
# .env is gitignored. NEVER commit real tokens.

# Slack user token (xoxp-...) for slack-mcp-server.
# Used by /update-feeds command to read #ai-feed channel.
# Obtain from: https://api.slack.com/apps → Your App → OAuth & Permissions → User OAuth Token
SLACK_USER_TOKEN=

# slack-mcp-server local HTTP endpoint (default: localhost:8000).
# Override only if you run the daemon on a different port.
SLACK_MCP_URL=http://localhost:8000/mcp
